#!/bin/sh

prev_ref=$1
branch_flag=$3

# Only run on worktree creation (null previous ref + branch checkout)
if [ "$branch_flag" != "1" ] || [ "$prev_ref" != "0000000000000000000000000000000000000000" ]; then
  exit 0
fi

# Resolve the main worktree root
main_worktree=$(git worktree list --porcelain | head -1 | sed 's/^worktree //')
current_dir=$(pwd)

# Copy all .env.local files from main worktree, preserving relative paths
(cd "$main_worktree" && find . -name ".env.local" -type f) | while read -r env_file; do
  src="$main_worktree/$env_file"
  dest="$current_dir/$env_file"
  mkdir -p "$(dirname "$dest")"
  cp "$src" "$dest"
  echo "Copied $env_file"
done

# Copy .claude/settings.local.json if it exists
settings_file="$main_worktree/.claude/settings.local.json"
if [ -f "$settings_file" ]; then
  mkdir -p "$current_dir/.claude"
  cp "$settings_file" "$current_dir/.claude/settings.local.json"
  echo "Copied .claude/settings.local.json"
fi

pnpm install
pnpm build
