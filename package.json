{
  "name": "camox-monorepo",
  "version": "0.8.0",
  "private": true,
  "author": "",
  "scripts": {
    "build": "nx run-many -t build --all",
    "dev": "nx run-many -t dev --all --parallel=10",
    "dev:servers": "nx run-many -t dev -p @camox/api web --parallel=10",
    "lint": "nx run-many -t lint --all",
    "test": "nx run-many -t test --all",
    "fmt": "oxfmt .",
    "check": "oxfmt . && nx run-many -t check --all --no-tui",
    "seed": "nx run @camox/api:seed",
    "deploy": "nx run-many -t deploy --all",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@typescript/native-preview": "7.0.0-dev.20260412.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "nx": "^21.6.10",
    "oxfmt": "^0.38.0"
  },
  "lint-staged": {
    "*": [
      "oxfmt",
      "nx affected -t check"
    ]
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "workerd"
    ],
    "overrides": {
      "react": "^19.2.5",
      "react-dom": "^19.2.5"
    }
  }
}
